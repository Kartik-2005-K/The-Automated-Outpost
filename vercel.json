{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "react",
  "regions": ["iad1"],
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.11"
    }
  },
  "env": [
    {
      "key": "VERCEL_ENV",
      "value": "production"
    }
  ]
}
